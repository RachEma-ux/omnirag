# ═══════════════════════════════════════════════════
# OmniRAG Port Registry — All services in 8100–8199
# ═══════════════════════════════════════════════════

# ─── Core Application ───
OMNIRAG_API_PORT=8100
OMNIRAG_WORKER_PORT=8101
OMNIRAG_EMBED_PORT=8102
OMNIRAG_WEBHOOK_PORT=8103
OMNIRAG_METRICS_PORT=8104

# ─── Graph Store (Neo4j) ───
NEO4J_BOLT_PORT=8110
NEO4J_HTTP_PORT=8111
NEO4J_AUTH=neo4j/omnirag
NEO4J_PLUGINS=apoc

# ─── Vector Store (Qdrant) ───
QDRANT_PORT=8120
QDRANT_GRPC_PORT=8121

# ─── Keyword Index (Elasticsearch) ───
ELASTICSEARCH_PORT=8130

# ─── Cache + Consistency (Redis) ───
REDIS_PORT=8140

# ─── Local LLM (Ollama) ───
OLLAMA_PORT=8150
OLLAMA_MODEL=llama3

# ─── Control Plane DB (PostgreSQL) ───
POSTGRES_PORT=8160
POSTGRES_DB=omnirag
POSTGRES_USER=omnirag
POSTGRES_PASSWORD=omnirag

# ─── Connection Strings (derived) ───
DATABASE_URL=postgresql://omnirag:omnirag@localhost:8160/omnirag
NEO4J_URI=bolt://localhost:8110
REDIS_URL=redis://localhost:8140/0
QDRANT_HOST=localhost
QDRANT_PORT_INT=8120
ELASTICSEARCH_URL=http://localhost:8130
OLLAMA_HOST=http://localhost:8150
